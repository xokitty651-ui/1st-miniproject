# Server Configuration
PORT=5000
NODE_ENV=development

# Database - Using local MongoDB (falls back gracefully in dev mode)
MONGODB_URI=mongodb://localhost:27017/agrimarket
DB_NAME=agrimarket

# JWT Authentication
JWT_SECRET=agrimarket_development_secret_key_minimum_32_characters_12345
JWT_EXPIRE=7d

# Weather API (OpenWeatherMap)
OPENWEATHERMAP_API_KEY=demo_key_development

# Soil API
OPENLANDMAP_API_KEY=demo_key_development
AGROMONITORING_API_KEY=demo_key_development

# PayPal Configuration (Sandbox)
PAYPAL_CLIENT_ID=demo_client_id
PAYPAL_CLIENT_SECRET=demo_client_secret
PAYPAL_MODE=sandbox

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_demo
STRIPE_PUBLIC_KEY=pk_test_demo

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=demo@gmail.com
SMTP_PASSWORD=demo_password
SMTP_FROM=noreply@agrimarket.com

# Frontend URL
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif

# Logging
LOG_LEVEL=debug
