# AgriMarket Backend - Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# Server Configuration
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# Database Configuration
# ==========================================
# MongoDB Atlas (Recommended for production)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/agrimarket?retryWrites=true&w=majority

# Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/agrimarket

DB_NAME=agrimarket

# ==========================================
# JWT Configuration
# ==========================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long_here
JWT_EXPIRE=7d

# ==========================================
# Weather API Configuration
# ==========================================
# Get from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Get from: https://www.weatherapi.com
WEATHERAPI_KEY=your_weatherapi_key_here

# ==========================================
# Soil API Configuration
# ==========================================
# Get from: https://www.agromonitoring.com/api
AGROMONITORING_API_KEY=your_agromonitoring_key_here

# OpenLandMap API
OPENLANDMAP_API_KEY=your_openlandmap_key_here

# ==========================================
# PayPal Configuration
# ==========================================
# Get from: https://developer.paypal.com
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox

# ==========================================
# Stripe Configuration (Optional)
# ==========================================
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=your_stripe_public_key_here

# ==========================================
# Email Configuration
# ==========================================
# Using Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@agrimarket.com

# Using SendGrid (Optional)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Using Mailgun (Optional)
# MAILGUN_DOMAIN=your_mailgun_domain
# MAILGUN_API_KEY=your_mailgun_api_key

# ==========================================
# Frontend Configuration
# ==========================================
FRONTEND_URL=http://localhost:5500
FRONTEND_URL_PRODUCTION=https://yourdomain.com

# ==========================================
# File Upload Configuration
# ==========================================
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif
UPLOAD_DIR=./uploads

# ==========================================
# AWS S3 Configuration (Optional - for image storage)
# ==========================================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET_NAME=agrimarket-images
# AWS_REGION=us-east-1

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ==========================================
# Redis Configuration (Optional - for caching)
# ==========================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ==========================================
# Session Configuration
# ==========================================
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600000

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Security
# ==========================================
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:5500
ALLOWED_HOSTS=localhost,yourdomain.com

# ==========================================
# API Keys for Third-Party Services
# ==========================================
# Twilio (for SMS notifications)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Firebase (for notifications)
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_email

# ==========================================
# Analytics
# ==========================================
# Google Analytics
# GOOGLE_ANALYTICS_ID=your_analytics_id

# Sentry (for error tracking)
# SENTRY_DSN=your_sentry_dsn

# ==========================================
# Development Tools
# ==========================================
DEBUG=agrimarket:*
TESTING=false

# ==========================================
# Notifications
# ==========================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
